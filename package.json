{
  "name": "dotori",
  "description": "A personal Bun-powered declarative setup tool for macOS",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./providers": "./src/providers/index.ts"
  },
  "bin": {
    "dotori": "./src/cli.ts"
  },
  "scripts": {
    "dotori": "bun run src/cli.ts",
    "format": "biome format --write",
    "lint": "biome check",
    "lint:fix": "biome check --fix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest",
    "@types/plist": "^3.0.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "cac": "^7.0.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "plist": "^5.0.0",
    "zod": "^4.4.3"
  }
}
