{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "semicolons": "asNeeded",
            "quoteStyle": "single"
        }
    },
    "files": {
        "includes": [
            "src/**/*.{ts,tsx,js,jsx}",
            "config/**/*.{ts,tsx,js,jsx}"
        ]
    }
}
